# Copy to .env  (used by the Vite app — these are PUBLIC, safe to ship in the bundle)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Copy to .env.local  (used ONLY by `node src/seed.js` — NEVER prefixed with VITE_,
# so Vite never bundles it into the browser. Keep this secret.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
